rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if a user is an administrator
    function isAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role.lower() == 'administrador';
    }

    // Helper function to check if a user is a supervisor
    function isSupervisor() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role.lower() == 'supervisor';
    }

    // Allow authenticated users to read their own user document to get their role
    match /users/{userId} {
      allow read: if request.auth.uid == userId;
      // Only admins can create, update, or delete user roles
      allow write: if isAdmin();
    }

    // Products, Materials, Recipes, Operators, Equipos can only be managed by Admins
    match /{collection}/{docId} where collection in ['products', 'materials', 'recipes', 'operators', 'equipos'] {
      allow read: if request.auth != null; // Allow any authenticated user to read
      allow write: if isAdmin(); // Only admins can write
    }

    // Production Orders and Vales can be created by Admins and Supervisors
    match /{collection}/{docId} where collection in ['productionOrders', 'vales'] {
      allow read: if request.auth != null;
      allow create, update: if isAdmin() || isSupervisor();
      allow delete: if isAdmin();
    }
  }
}
