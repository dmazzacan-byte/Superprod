rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if the user's role document exists.
    function userDocExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    // Helper function to get the user's role document.
    function getUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    // Helper function to check if a user is an administrator.
    // This is now robust and checks for existence of the doc and field.
    function isAdmin() {
      return userDocExists()
        && 'role' in getUserDoc().data
        && getUserDoc().data.role.lower() == 'administrator';
    }

    // Helper function to check if a user is a supervisor.
    // This is now robust and checks for existence of the doc and field.
    function isSupervisor() {
      return userDocExists()
        && 'role' in getUserDoc().data
        && getUserDoc().data.role.lower() == 'supervisor';
    }

    // --- User Roles ---
    match /users/{userId} {
      // Any user can get their own document to check their role upon login.
      allow get: if request.auth.uid == userId;
      // Admins can get any user document, list all users for management, and write to any user document.
      allow read, write: if isAdmin();
    }

    // --- Admin-Managed Collections ---
    // Products, Materials, Recipes, Operators, and Equipos can only be written to by Admins.
    match /products/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    match /materials/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    match /recipes/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    match /operators/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    match /equipos/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // --- Operational Collections ---
    // Production Orders and Vales can be created/updated by Admins and Supervisors.
    match /productionOrders/{docId} {
      allow read: if request.auth != null;
      allow create, update: if isAdmin() || isSupervisor();
      allow delete: if isAdmin();
    }
    match /vales/{docId} {
      allow read: if request.auth != null;
      allow create, update: if isAdmin() || isSupervisor();
      allow delete: if isAdmin();
    }
  }
}
